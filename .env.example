# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key — BACKEND ONLY, never ship to the frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon/publishable key (used for some auth admin flows)
SUPABASE_ANON_KEY=your-anon-key
# JWT secret OR rely on JWKS discovery via SUPABASE_URL (preferred)
SUPABASE_JWT_SECRET=your-legacy-jwt-secret

# ── Anthropic / Claude (BOQ → RFQ extraction) ────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model used to separate BOQ materials into categories (Opus 4.8)
CLAUDE_BOQ_MODEL=claude-opus-4-8
CLAUDE_BOQ_MAX_TOKENS=16000

# ── Microsoft Graph (email send-as bids@g3electrical.com) ────────────────
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-app-client-id
MS_CLIENT_SECRET=your-app-client-secret
MS_SENDER=bids@g3electrical.com

# ── App ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:4500
# Short-TTL (seconds) for signed file URLs handed to estimators
SIGNED_URL_TTL_SECONDS=900
